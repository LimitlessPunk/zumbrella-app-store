#!/usr/bin/env bash

set -euo pipefail

APP_DATA_DIR="$(readlink -f "$(dirname "${BASH_SOURCE[0]}")/../data")"
DESIRED_OWNER="1000:1000"

# Create data directories
mkdir -p "${APP_DATA_DIR}/zebrad"
mkdir -p "${APP_DATA_DIR}/lightwalletd/db"
mkdir -p "${APP_DATA_DIR}/settings"

# lightwalletd reads zcash.conf for RPC connection details. It requires a
# non-empty rpcpassword (even though zebrad has cookie auth disabled) and
# uses rpcbind to find the node (ignoring the --rpchost CLI flag).
cat > "${APP_DATA_DIR}/lightwalletd/zcash.conf" <<CONF
rpcpassword=noauth
rpcbind=${APP_ZUMBRELLA_ZCASH_NODE_ZEBRAD_IP}
rpcport=8232
CONF

# Generate envoy.yaml for gRPC-web proxy (regenerated on every start to pick up updates)
cat > "${APP_DATA_DIR}/envoy.yaml" <<'ENVOY'
static_resources:
  listeners:
    - name: listener_0
      address:
        socket_address:
          address: 0.0.0.0
          port_value: 8080
      filter_chains:
        - filters:
            - name: envoy.filters.network.http_connection_manager
              typed_config:
                "@type": type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager
                codec_type: AUTO
                stat_prefix: ingress_http
                route_config:
                  name: local_route
                  virtual_hosts:
                    - name: local_service
                      domains: ["*"]
                      routes:
                        - match:
                            prefix: "/"
                          route:
                            cluster: lightwalletd
                            timeout: 0s
                            max_stream_duration:
                              grpc_timeout_header_max: 0s
                      cors:
                        allow_origin_string_match:
                          - prefix: "*"
                        allow_methods: GET, PUT, DELETE, POST, OPTIONS
                        allow_headers: keep-alive,user-agent,cache-control,content-type,content-transfer-encoding,x-accept-content-transfer-encoding,x-accept-response-streaming,x-user-agent,x-grpc-web,grpc-timeout
                        max_age: "1728000"
                        expose_headers: grpc-status,grpc-message
                http_filters:
                  - name: envoy.filters.http.grpc_web
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.grpc_web.v3.GrpcWeb
                  - name: envoy.filters.http.cors
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.cors.v3.Cors
                  - name: envoy.filters.http.router
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.router.v3.Router
  clusters:
    - name: lightwalletd
      connect_timeout: 5s
      type: LOGICAL_DNS
      lb_policy: ROUND_ROBIN
      typed_extension_protocol_options:
        envoy.extensions.upstreams.http.v3.HttpProtocolOptions:
          "@type": type.googleapis.com/envoy.extensions.upstreams.http.v3.HttpProtocolOptions
          explicit_http_config:
            http2_protocol_options: {}
      load_assignment:
        cluster_name: lightwalletd
        endpoints:
          - lb_endpoints:
              - endpoint:
                  address:
                    socket_address:
                      address: lightwalletd
                      port_value: 9067
ENVOY

# Read user settings and export as env vars
SETTINGS_FILE="${APP_DATA_DIR}/settings/settings.json"
if [[ -f "${SETTINGS_FILE}" ]]; then
  MINER_ADDR=$(jq -r '.minerAddress // empty' "${SETTINGS_FILE}" 2>/dev/null)
  LOG_LEVEL=$(jq -r '.logLevel // empty' "${SETTINGS_FILE}" 2>/dev/null)
  P2P_PORT=$(jq -r '.p2pPort // empty' "${SETTINGS_FILE}" 2>/dev/null)
  MAX_CONN=$(jq -r '.maxConnections // empty' "${SETTINGS_FILE}" 2>/dev/null)
  CACHE_GB=$(jq -r '.cacheSizeGb // empty' "${SETTINGS_FILE}" 2>/dev/null)

  [[ -n "${MINER_ADDR}" ]] && export APP_ZUMBRELLA_ZCASH_NODE_MINER_ADDRESS="${MINER_ADDR}"
  [[ -n "${LOG_LEVEL}" ]] && export APP_ZUMBRELLA_ZCASH_NODE_LOG_LEVEL="${LOG_LEVEL}"
  [[ -n "${P2P_PORT}" ]] && export APP_ZUMBRELLA_ZCASH_NODE_P2P_PORT="${P2P_PORT}"
  [[ -n "${MAX_CONN}" ]] && export APP_ZUMBRELLA_ZCASH_NODE_MAX_CONNECTIONS="${MAX_CONN}"
  [[ -n "${CACHE_GB}" && "${CACHE_GB}" != "0" ]] && export APP_ZUMBRELLA_ZCASH_NODE_CACHE_SIZE="${CACHE_GB}"

  SYNC_CONC=$(jq -r '.syncConcurrency // empty' "${SETTINGS_FILE}" 2>/dev/null)
  [[ -n "${SYNC_CONC}" ]] && export APP_ZUMBRELLA_ZCASH_NODE_SYNC_CONCURRENCY="${SYNC_CONC}"
fi

# Fix file ownership for containers running as uid 1000
chown -R "${DESIRED_OWNER}" "${APP_DATA_DIR}/zebrad" || true
chown -R "${DESIRED_OWNER}" "${APP_DATA_DIR}/lightwalletd" || true
chown -R "${DESIRED_OWNER}" "${APP_DATA_DIR}/settings" || true

# Bootstrap Tor hidden services
HIDDEN_SERVICE_FILE="${TOR_DATA_DIR}/app-zumbrella-zcash-node-rpc/hostname"

if [[ -f "${HIDDEN_SERVICE_FILE}" ]]; then
    exit
fi

"${UMBREL_ROOT}/scripts/app" compose "${APP_ID}" up --detach tor

echo "App: ${APP_ID} - Generating Tor Hidden Services..."
for attempt in $(seq 1 100); do
    if [[ -f "${HIDDEN_SERVICE_FILE}" ]]; then
        echo "Hidden services ready!"
        break
    fi
    sleep 0.1
done
